<Window x:Class="SmartNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartNotes.ViewModels"
        mc:Ignorable="d"
        Title="智能便签"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 圆润按钮样式 -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F5"/>
                                <Setter Property="BorderBrush" Value="#007AFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E5E5EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主色调按钮 -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007AFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0056CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004499"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- AI 按钮样式 -->
        <Style x:Key="AIButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#34C759"/>
            <Setter Property="BorderBrush" Value="#34C759"/>
        </Style>

        <!-- 便签卡片样式 -->
        <Style x:Key="NoteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 搜索框样式 -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 分类按钮样式 -->
        <Style x:Key="CategoryButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007AFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#0056CC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 主布局 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧边栏 -->
        <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <StackPanel Grid.Row="0" Margin="20,20,20,10">
                    <TextBlock Text="📝" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="智能便签" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1C1C1E" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- 新建按钮 -->
                <Button Grid.Row="1"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateNoteCommand}"
                        Margin="20,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,6,0"/>
                        <TextBlock Text="新建便签"/>
                    </StackPanel>
                </Button>

                <!-- AI 助手按钮 -->
                <Button Grid.Row="2"
                        Style="{StaticResource AIButton}"
                        Command="{Binding OpenAIAssistantCommand}"
                        Margin="20,5,20,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="AI 助手"/>
                    </StackPanel>
                </Button>

                <!-- 分类列表 -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,0">
                        <TextBlock Text="分类" FontSize="12" FontWeight="Medium"
                                   Foreground="#8E8E93" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="border"
                                                        Background="Transparent"
                                                        CornerRadius="16"
                                                        Padding="12,8"
                                                        Margin="0,2"
                                                        Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#007AFF"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#F0F0F5"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="border" Property="Background" Value="#0056CC"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- 设置按钮 -->
                <Button Grid.Row="4"
                        Style="{StaticResource RoundedButton}"
                        Command="{Binding ToggleSettingsCommand}"
                        Margin="20,10,20,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="设置"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 右侧主内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 搜索栏 -->
            <Border Grid.Row="0" Background="White" Padding="20,15">
                <TextBox Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="搜索便签..."/>
            </Border>

            <!-- 便签列表/编辑器 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 便签列表 -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                    <ItemsControl ItemsSource="{Binding Notes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource NoteCard}"
                                        MouseLeftButtonDown="NoteCard_MouseLeftButtonDown"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="#1C1C1E" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="200"/>
                                            <TextBlock Text="📌" FontSize="12" Margin="6,0,0,0"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="🤖" FontSize="12" Margin="6,0,0,0"
                                                       Visibility="{Binding IsAIGenerated, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Text="{Binding Content}"
                                                   FontSize="13" Foreground="#636366"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40" Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Background="#F2F2F7" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#8E8E93"/>
                                            </Border>
                                            <TextBlock Text="{Binding ModifiedTime, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                       FontSize="11" Foreground="#C7C7CC" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 便签编辑器 -->
                <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Direction="270"/>
                    </Border.Effect>

                    <Grid Visibility="{Binding SelectedNote, Converter={StaticResource NullToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <TextBox Grid.Row="0"
                                 Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20" FontWeight="SemiBold"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="#1C1C1E"/>

                        <!-- 元信息 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,15">
                            <Border Background="#F2F2F7" CornerRadius="6" Padding="8,4">
                                <TextBlock Text="{Binding SelectedNote.Category}" FontSize="12" Foreground="#636366"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedNote.ModifiedTime, StringFormat='修改于 {0:yyyy年MM月dd日 HH:mm}'}"
                                       FontSize="12" Foreground="#C7C7CC" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 内容编辑区 -->
                        <TextBox Grid.Row="2"
                                 Text="{Binding SelectedNote.Content, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Foreground="#333333"
                                 BorderThickness="0" Background="Transparent"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <!-- 操作按钮 -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
                            <Button Style="{StaticResource RoundedButton}"
                                    Command="{Binding SaveNoteCommand}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="保存"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RoundedButton}"
                                    Command="{Binding TogglePinCommand}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedNote.IsPinned, Converter={StaticResource PinIconConverter}}"
                                               FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SelectedNote.IsPinned, Converter={StaticResource PinTextConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RoundedButton}"
                                    Command="{Binding DeleteNoteCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑️" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="删除"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="20,10" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#8E8E93"/>
            </Border>
        </Grid>

        <!-- 设置面板 (浮层) -->
        <Border Grid.ColumnSpan="2"
                Background="#80000000"
                Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" CornerRadius="20"
                    Width="420" Height="420"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.2"/>
                </Border.Effect>

                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="⚙️ API 设置" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1C1C1E" Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="280">
                        <StackPanel>
                            <TextBlock Text="API 密钥" FontSize="13" Foreground="#636366" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="ApiKeyBox"
                                         FontSize="14" Padding="12,10"
                                         BorderBrush="#E0E0E0" BorderThickness="1"
                                         Background="White"/>

                            <TextBlock Text="API 地址" FontSize="13" Foreground="#636366" Margin="0,15,0,6"/>
                            <TextBox Text="{Binding ApiEndpoint}"
                                     FontSize="14" Padding="12,10"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Text="AI 模型" FontSize="13" Foreground="#636366" Margin="0,15,0,6"/>
                            <TextBox Text="{Binding AiModel}"
                                     FontSize="14" Padding="12,10"
                                     BorderBrush="#E0E0E0" BorderThickness="1"/>

                            <TextBlock Text="💡 默认使用火山引擎豆包大模型 API" FontSize="12"
                                       Foreground="#8E8E93" Margin="0,15,0,10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Style="{StaticResource RoundedButton}"
                                Content="取消"
                                Command="{Binding ToggleSettingsCommand}"
                                Margin="0,0,10,0"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="保存"
                                Click="SaveSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- AI 生成面板 (浮层) -->
        <Border Grid.ColumnSpan="2"
                Background="#80000000"
                Visibility="{Binding IsAIGenerating, Converter={StaticResource BoolToVis}}">
            <Border Background="White" CornerRadius="20"
                    Width="500" Height="400"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.2"/>
                </Border.Effect>

                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖" FontSize="24" Margin="0,0,10,0"/>
                            <TextBlock Text="AI 计划助手" FontSize="20" FontWeight="SemiBold" Foreground="#1C1C1E"/>
                        </StackPanel>
                        <TextBlock Text="描述您的需求，AI 将为您制定详细计划" FontSize="13" Foreground="#8E8E93" Margin="0,5,0,0"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding AiPrompt, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Foreground="#333333"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Padding="15" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Style="{StaticResource RoundedButton}"
                                Content="取消"
                                Command="{Binding CancelAIGenerationCommand}"
                                Margin="0,0,10,0"/>
                        <Button Style="{StaticResource AIButton}"
                                Content="🚀 生成计划"
                                Command="{Binding GeneratePlanCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- 加载指示器 -->
        <Border Grid.ColumnSpan="2" Background="#40000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="处理中..." FontSize="16" Foreground="White" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
