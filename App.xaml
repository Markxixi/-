<Application x:Class="SmartNotes.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SmartNotes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 全局转换器 -->
            <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <local:EqualConverter x:Key="EqualConverter"/>
            <local:PinIconConverter x:Key="PinIconConverter"/>
            <local:PinTextConverter x:Key="PinTextConverter"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
